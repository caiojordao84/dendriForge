canvas:
  width: 70
  height: 90
  ports_layout: custom
  port_VCC: {x: 0, y: 8}
  port_GND: {x: 0, y: 20}
  port_RST: {x: 0, y: 34}
  port_IRQ: {x: 0, y: 48}
  port_MISO: {x: 70, y: 14}
  port_MOSI: {x: 70, y: 28}
  port_SCK: {x: 70, y: 42}
  port_SDA: {x: 70, y: 56}
  label_position: top
  value_display: "13.56 MHz / {interface} / {read_range}mm range"
  animated: true

