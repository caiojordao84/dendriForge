  5|digital|f|f|"GPIO5 — M-Bus GPIO free (pin 10)"|"di;do"
  6|digital|f|f|"GPIO6 — M-Bus GPIO free (pin 21)"|"di;do"
  7|digital|f|f|"GPIO7 — M-Bus GPIO free (pin 22)"|"di;do"
  8|digital|f|f|"GPIO8 — Grove PORT.B IN (HY2.0-4P)"|"di;do"
  9|digital|f|f|"GPIO9 — Grove PORT.B OUT (HY2.0-4P)"|"di;do"
  10|analog|f|f|"GPIO10 — ADC; M-Bus pin 2"|"di;do"
  11|digital|f|f|"GPIO11 — Internal I2C SCL (AXP2101; FT6336U; BMI270; BM8563; ES7210; AW88298; LTR-553; GC0308; AW9523B); do not use as free GPIO"|"i2c-scl"
  12|digital|f|f|"GPIO12 — Internal I2C SDA (same internal bus as GPIO11); do not use as free GPIO"|"i2c-sda"
  13|digital|f|f|"GPIO13 — I2S DOUT to AW88298 speaker amplifier"|"i2s"
  14|digital|f|f|"GPIO14 — I2S DIN from ES7210 microphone codec"|"i2s"
  17|digital|f|f|"GPIO17 — Grove PORT.C RX (HY2.0-4P)"|"uart-rx"
  18|digital|f|f|"GPIO18 — Grove PORT.C TX (HY2.0-4P)"|"uart-tx"
  43|digital|f|f|"GPIO43 — UART0 TX; M-Bus TXD0; Arduino Serial TX"|"uart-tx"
  44|digital|f|f|"GPIO44 — UART0 RX; M-Bus RXD0; Arduino Serial RX"|"uart-rx"

