## 4. GPIO MAP:
gpio[23|]{pin|type|pwm|int|label|roles}:
  1|digital|f|f|"GPIO1 — UART0 TX; P1 connector TX; shared with CH340C USB-serial; do not use while USB CDC active"|"uart-tx"
  2|digital|f|f|"GPIO2 — TFT DC (ILI9341 data/command select; HSPI bus); strapping pin — must be LOW at boot for download mode, HIGH for normal boot"|"spi"
  3|digital|f|f|"GPIO3 — UART0 RX; P1 connector RX; shared with CH340C; do not use while USB CDC active"|"uart-rx"
  4|digital|t|f|"GPIO4 — RGB LED Red (active-LOW; inverted logic; PWM capable)"|"status-led"
  5|digital|f|f|"GPIO5 — microSD CS (VSPI bus; CS for SD card)"|"spi"
  13|digital|t|f|"GPIO13 — TFT MOSI (ILI9341 HSPI MOSI; shared SPI bus for display only)"|"spi"
  14|digital|t|f|"GPIO14 — TFT SCK (ILI9341 HSPI clock)"|"spi"
  15|digital|f|f|"GPIO15 — TFT CS (ILI9341 chip-select; HSPI)"|"spi"
  16|digital|t|f|"GPIO16 — RGB LED Green (active-LOW; inverted logic; shared with TFT MISO on some board revisions — verify before use)"|"status-led"
  17|digital|t|f|"GPIO17 — RGB LED Blue (active-LOW; inverted logic; PWM capable)"|"status-led"
  18|digital|f|f|"GPIO18 — microSD SCK (VSPI; shared with touchscreen XPT2046)"|"spi"
  19|digital|f|f|"GPIO19 — microSD MISO (VSPI; shared with touchscreen MISO)"|"spi"
  21|digital|t|f|"GPIO21 — TFT Backlight control (HIGH=on; LOW=off); also exposed on P3 connector; avoid using as free GPIO while backlight is needed"|"do"
  22|digital|f|f|"GPIO22 — Free GPIO; exposed on P3 and CN1 connectors; recommended for I2C SCL (external sensors)"|"di;do"
  23|digital|f|f|"GPIO23 — microSD MOSI (VSPI; shared with touchscreen MOSI)"|"spi"
  25|digital|t|f|"GPIO25 — Touch XPT2046 SCK (VSPI); also DAC1 output; PWM capable"|"spi"
  26|digital|t|f|"GPIO26 — Speaker output (1.25mm JST connector; DAC or PWM audio); DAC2 output; do not drive speaker directly without amplifier stage"|"do"
  27|digital|f|f|"GPIO27 — Free GPIO; exposed on CN1 connector; R18 10k pull-up to 3.3V fitted on PCB; analogRead returns 4095 if unconnected; suitable for I2C SDA external sensors"|"di;do"
  33|digital|f|f|"GPIO33 — Touch XPT2046 CS (VSPI)"|"spi"
  34|analog|f|f|"GPIO34 — LDR light sensor (input only; 1M pull-up R15 + 1M R19 parallel to GND; low sensitivity as shipped; consider replacing R15 with 10k for better range); INPUT ONLY — no output capability"|"di"
  35|analog|f|f|"GPIO35 — Free GPIO on P3 connector; INPUT ONLY — no output; 12-bit ADC channel; do not attempt to drive as output"|"di"
  36|analog|f|f|"GPIO36 — Touch XPT2046 IRQ (input only; interrupt from touch controller)"|"di"
  39|analog|f|f|"GPIO39 — Touch XPT2046 MISO (VSPI; input only — INPUT ONLY pin)"|"di"

## 5. PERIPHERALS & USB:
peripherals[4|]{peripheral|param|value}:
  serial|uart0|"tx1|rx3"
  spi|channels2|"hspi:mosi13|sck14|cs15|dc2-tft;vspi:mosi23|miso19|sck18|cs5-sd|cs33-touch"
  i2c|channels1|"sda27|scl22"
  adc|channels1|"gpio34-ldr|gpio35|gpio36-touch-irq|gpio39"
